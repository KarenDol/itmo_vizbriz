    "intro": {
      "title_en": "VizBriz SQUARE Sleep Quality and Appliance Response Evaluation Follow-Up Questionnaire",
      "subtitle_en": "This questionnaire is designed to help us understand your experience since starting oral appliance therapy.",
      "body_en": "Your responses will help us evaluate changes in your sleep, daytime symptoms, snoring, and overall treatment experience, and determine whether any adjustments may be beneficial. Please answer all questions as accurately as possible. There are no right or wrong answers. All questions are required except Question 24. Your name and email are provided automatically from your personalized link.",
      "title_he": "הערכת איכות שינה ותגובה לטיפול באמצעות התקן דנטלי",
      "subtitle_he": "שאלון זה נועד לעזור לנו להבין את החוויה שלך מאז התחלת להשתמש בהתקן הדנטלי.",
      "body_he": "התשובות שלך יסייעו לנו להעריך שינויים בשינה, בתסמינים במהלך היום, בנחירות ובחוויה הכללית מהטיפול, ולבחון האם יש צורך בהתאמות נוספות. אנא השב/י על כל השאלות בצורה המדויקת ביותר האפשרית. אין תשובות נכונות או לא נכונות."
    },
    "display_groups": {
      "Section_Treatment": {
        "title": "Treatment Information",
        "title_he": "מידע על הטיפול"
      },
      "Section_1": {
        "title": "1. Oral Appliance Use",
        "title_he": "שימוש בהתקן"
      },
      "Section_2": {
        "title": "2. Sleep and Daytime Symptoms",
        "title_he": "שינה ותסמינים במהלך היום"
      },
      "Section_3": {
        "title": "3. Snoring",
        "title_he": "נחירות"
      },
      "Section_4": {
        "title": "4. Additional Information",
        "title_he": "מידע נוסף"
      }
    },
    "section_title_he": {
      "Treatment Information": "מידע על הטיפול",
