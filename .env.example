# Copy to .env and fill in values. Never commit .env.

# Flask
SECRET_KEY=change-me-to-a-random-string
ENVIRONMENT=development
BASE_URL=http://localhost:7000
DISABLE_LLM_CALLS=true

# Database (MySQL)
DB_USERNAME=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vizbriz

# AWS (S3, Bedrock, Textract)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
S3_BUCKET_NAME=your-bucket-name
BEDROCK_AWS_REGION=us-west-2

# Bedrock Knowledge Bases (optional — for RAG-grounded reports)
BEDROCK_KB_ID=
BEDROCK_KB_LEVEL4_STYLE_ID=
BEDROCK_KB_LEVEL4_CLINIC_ID=

# OpenAI (sleep study pipeline, Level-4 reports)
OPENAI_API_KEY=
SLEEP_STUDY_OPENAI_API_KEY=
LEVEL4_OPENAI_API_KEY=

# Anthropic (optional legacy paths)
ANTHROPIC_API_KEY=
LEVEL4_ANTHROPIC_API_KEY=

# Email / integrations (optional)
SENDGRID_API_KEY=
TINYURL_API_TOKEN=
GOOGLE_TTS_JSON=

# Internal API tokens (optional)
EXTRACTION_API_KEY=
LEVEL_1_REPORT_API_TOKEN=
