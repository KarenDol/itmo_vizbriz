    "Lamberg_Protocol": {
      "version": "lamberg_protocol_v1",
      "generated_at": "2025-08-12T17:13:40.941019",
      "source": {
        "name": "Personalization of Diagnosing The Cause and Selecting the Treatment for Sleep-Related Breathing Disorders: The Lamberg Protocol",
        "author": "Steve Lamberg DDS, DABDSM",
        "date": "2025-06-12"
      },
      "decision_flow": [
        {
          "step": "screen_all_adults",
          "tool": "Lamberg_Questionnaire_LQ_v16",
          "trigger": "adult_encounter",
          "next_if": [
            {
              "condition": "LQ_score>=2",
              "go_to": "order_PSG_or_HSAT"
            },
            {
              "condition": "LQ_score<2",
              "go_to": "finish_low_risk_with_education"
            }
          ]
        },
        {
          "step": "screen_pediatrics",
          "tool": "LQ_PAS",
          "trigger": "pediatric_encounter",
          "next_if": [
            {
              "condition": "LQ_PAS_positive==true",
              "go_to": "order_PSG_or_HSAT"
            },
            {
              "condition": "LQ_PAS_positive==false",
              "go_to": "finish_low_risk_with_education"
            }
          ]
        },
        {
          "step": "order_PSG_or_HSAT",
          "action": "schedule_sleep_test",
          "notes": "If PSG/HSAT negative for OSA, evaluate UARS; if positive for OSA, proceed to Nextgen Data Collection."
        },
        {
          "step": "uars_screen_if_OSA_negative",
          "action": "screen_for_UARS",
          "enter_if": "sleep_test_result==negative_for_OSA",
          "uars_criteria": [
            "AHI<5",
            "SpO2_nadir>=92",
            "RERA_index>=5_per_hour OR airflow_limitation_during_sleep>=5_percent_TST AND daytime_sleepiness_or_fatigue==true"
          ],
          "next_if": [
            {
              "condition": "UARS_positive==true",
              "go_to": "Nextgen_Data_Collection"
            },
            {
              "condition": "UARS_positive==false",
              "go_to": "administer_ISI_and_manage_as_indicated"
            }
          ]
        },
        {
          "step": "administer_ISI_and_manage_as_indicated",
          "action": "administer_Insomnia_Severity_Index",
          "notes": "Screen for insomnia (ISI) in UARS-negative and all patients due to high co-occurrence with OSA/UARS."
        },
        {
          "step": "Nextgen_Data_Collection",
          "action": "collect_nextgen_data",
          "notes": "Collect Structure, Function, Behavior + genetics and lifestyle risk factors; then map to treatment targets; ensure transdisciplinary referrals as indicated.",
          "go_to": "Targeted_Treatment_Algorithms"
        },
        {
          "step": "Targeted_Treatment_Algorithms",
          "action": "select_treatment_targets_and_interventions",
          "notes": "Connect diagnosed compensations/causes to specific interventions; schedule follow-up efficacy testing."
        }
      ],
      "action_mapping_additions": {
        "administer_LQ_adult": {
          "action_key": "administer_questionnaire",
          "defaults": {
            "questionnaire_id": "LQ_v16"
          },
          "required_params": [
            "patient_id",
            "questionnaire_id"
          ]
        },
        "administer_LQ_PAS": {
